# Email autorizado para acceder a la aplicación (OPCIONAL)
# Si no se configuran, cualquier usuario con GitHub puede acceder
# Si se configuran, solo ese email podrá acceder
# IMPORTANTE: Configura AMBAS variables para que funcione correctamente
ALLOWED_EMAIL=tu-email@github.com
NEXT_PUBLIC_ALLOWED_EMAIL=tu-email@github.com

# Auth por email + password (Credentials)
# Email permitido para login
AUTH_EMAIL=tu-email@github.com
# Hash bcrypt de la contraseña. Generar con:
#   node -e "console.log(require('bcryptjs').hashSync('tu-password', 10))"
AUTH_PASSWORD_HASH=$2b$10$...

# Variables de MongoDB
# Obtén estas credenciales desde tu cluster de MongoDB Atlas o instancia local
MONGODB_URI=mongodb+srv://user:password@cluster/dbname?retryWrites=true&w=majority
MONGODB_DB=linkeee

# Variables de GitHub OAuth (OPCIONAL - solo si quieres ofrecer login con GitHub)
# Si se comentan/vacían, el botón de GitHub no aparece y solo se usa email+password
# Obtén estas credenciales desde GitHub Developer Settings
GITHUB_ID=tu-github-client-id
GITHUB_SECRET=tu-github-client-secret
NEXT_PUBLIC_GITHUB_ID=

# Variable de NextAuth
# Genera una clave secreta aleatoria
NEXTAUTH_SECRET=tu-nextauth-secret-aqui

# Variable para URL Meta API
# Obtén tu Bearer Token desde https://urlmeta.org/dashboard
URLMETA_API_KEY=tu-bearer-token-aqui